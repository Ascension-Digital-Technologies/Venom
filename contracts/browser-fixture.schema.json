{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://venom-runtime.dev/contracts/browser-fixture.schema.json",
  "title": "Venom browser fixture manifest",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "scenarios"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "scenarios": {
      "type": "array",
      "minItems": 1
    },
    "profile": {
      "type": "string",
      "minLength": 1
    },
    "evidence_level": {
      "enum": [
        "smoke",
        "behavioral",
        "conformance"
      ]
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "support_tier": {
      "enum": [
        "probe",
        "candidate",
        "supported"
      ]
    },
    "framework": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "delivery": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "name",
        "version"
      ],
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
