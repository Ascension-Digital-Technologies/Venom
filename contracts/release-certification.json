  "browserFixtures": [
    {
      "id": "javascript-playground",
      "profile": "prod",
      "required": true
    },
    {
      "id": "aegis-operations",
      "profile": "prod",
      "required": true
    }
  ],
  "releaseClaims": [
    "TurboJS/WASM bytecode execution is required for protected browser code",
    "Host JavaScript source fallback is denied",
    "TypeScript and TSX are structurally lowered before runtime planning",
    "Protected production distributions pass runtime verification and leak scanning",
    "Playground executions use isolated, resource-bounded TurboJS contexts",
    "Vite integration preserves explicit browser/protected runtime boundaries",
    "Stable application integration uses the versioned @venom/runtime API"
  ]
}
