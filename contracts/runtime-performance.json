{
  "schema": "VENOM_RUNTIME_PERFORMANCE_V1",
  "version": 1,
  "measurement": {
    "clock": "performance.now",
    "warmupRuns": 1,
    "measuredRuns": 5,
    "aggregation": ["median", "p95"]
  },
  "budgetsMs": {
    "complete": {"median": 3000, "p95": 5000},
    "package-load": {"median": 800, "p95": 1500},
    "package-policy": {"median": 900, "p95": 1800},
    "runtime-install": {"median": 1500, "p95": 3000},
    "route-decode": {"median": 500, "p95": 1000},
    "script-execution": {"median": 800, "p95": 1600}
  },
  "preloadPolicy": {
    "required": true,
    "assets": ["loader", "runtime", "package", "turbojs-wasm", "worker"],
    "cacheMode": "http-cache-only",
    "persistentPlaintextCacheAllowed": false
  },
  "failurePolicy": {
    "budgetRegressionFailsCertification": true,
    "missingTimelineFailsCertification": true
  }
}
