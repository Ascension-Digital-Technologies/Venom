# Venom - Secure Web Runtime project configuration
[project]
name = "example-site"
entry = "examples/protected-chess"
output = "dist"

[build]
harden_public_javascript = true
vendor_cache = ".venom/vendor-cache"
vendor_lock = "examples/protected-chess/venom.lock"
offline = false
refresh_vendors = false

[runtime]
engine = "turbojs-wasm"
fail_closed = true

[security]
deny_host_js_fallback = true
require_audited_crypto = false

[compatibility]
minimum_chrome = 120
minimum_firefox = 121
minimum_safari = 17

[capabilities]
fetch = "auto"
timers = "auto"
storage = "auto"
crypto = "auto"
