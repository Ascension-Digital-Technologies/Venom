root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.{c,cc,cpp,h,hpp}]
indent_style = space
indent_size = 2

[*.{cmake,md,py,sh,yml,yaml,json,toml,js,mjs}]
indent_style = space
indent_size = 2

[*.{bat,ps1}]
end_of_line = crlf
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab
