{
  "manifest_version": 3,
  "name": "Isolated content fixture",
  "version": "1.0.0",
  "host_permissions": [
    "http://127.0.0.1/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "http://127.0.0.1/*"
      ],
      "js": [
        "content-dep.js",
        "content.js"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}